{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "A domain workspace profile (e.g., Dev, Marketing, Sales).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "An automation workflow definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "triggerType": { "type": "string", "enum": ["manual", "webhook", "scheduled", "event"] },
        "status": { "type": "string", "enum": ["active", "disabled", "draft"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["profileId", "name", "triggerType", "status", "ownerId", "createdAt"]
    },
    "Run": {
      "title": "Run",
      "description": "An execution instance of a workflow.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workflowId": { "type": "string" },
        "profileId": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "running", "awaiting_approval", "completed", "failed", "cancelled"] },
        "ownerId": { "type": "string" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "error": { "type": "string" }
      },
      "required": ["workflowId", "profileId", "status", "ownerId", "startedAt"]
    },
    "Approval": {
      "title": "Approval",
      "description": "A pending or completed approval request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "runId": { "type": "string" },
        "workflowId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" },
        "resolvedBy": { "type": "string" },
        "ownerId": { "type": "string" },
        "payload": { "type": "string" }
      },
      "required": ["runId", "workflowId", "status", "requestedAt", "ownerId"]
    },
    "Alert": {
      "title": "Alert",
      "description": "System alerts and notifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
        "status": { "type": "string", "enum": ["unread", "read", "resolved"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "severity", "status", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "profiles": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "Domain workspaces"
    },
    "workflows": {
      "schema": { "$ref": "#/entities/Workflow" },
      "description": "Workflow definitions"
    },
    "runs": {
      "schema": { "$ref": "#/entities/Run" },
      "description": "Workflow execution runs"
    },
    "approvals": {
      "schema": { "$ref": "#/entities/Approval" },
      "description": "Approval requests"
    },
    "alerts": {
      "schema": { "$ref": "#/entities/Alert" },
      "description": "System alerts"
    }
  }
}
